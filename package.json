{
  "name": "date-range-picker-cn",
  "version": "0.0.2",
  "private": false,
  "keywords": [
    "base-ui",
    "calendar",
    "date-picker",
    "date-range-picker",
    "radix-ui",
    "react",
    "shadcn",
    "tanstack-intent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peppyhop/date-range-picker-cn.git"
  },
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts"
  ],
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./base": {
      "import": "./dist/base/index.es.js",
      "require": "./dist/base/index.umd.js",
      "types": "./dist/base/index.d.ts"
    },
    "./radix": {
      "import": "./dist/radix/index.es.js",
      "require": "./dist/radix/index.umd.js",
      "types": "./dist/radix/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:site",
    "build:site": "vite build",
    "build:lib": "vite build -c vite.config.lib.root.ts && vite build -c vite.config.lib.base.ts && vite build -c vite.config.lib.radix.ts && tsc -p tsconfig.build.json",
    "test": "npm run test:browser",
    "test:browser": "TZ=UTC vitest --browser --run",
    "commitlint": "commitlint --verbose",
    "docs": "npm run docs:api",
    "docs:api": "typedoc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:staged": "lint-staged",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "preview": "vite preview",
    "build:package": "npm run build:lib",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/intent": "^0.0.27",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.7.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "^4.2.2",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  }
}
